<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <SurfaceView
        android:id="@+id/surfaceView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Left top: Status panel -->
    <LinearLayout
        android:id="@+id/statusPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_status_panel"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvLatency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvResolution"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvFps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvBitrate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvTraffic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvSignal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvVoltage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvSsh"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/status_text"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Top right: Rear camera small window -->
    <FrameLayout
        android:id="@+id/rearCamContainer"
        android:layout_width="240dp"
        android:layout_height="180dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="88dp"
        android:visibility="gone">

        <SurfaceView
            android:id="@+id/surfaceViewRearCam"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- Top center: GPS speed -->
    <TextView
        android:id="@+id/tvGpsSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="12dp"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:visibility="gone" />

    <!-- Right top: Control buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end|top"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="12dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnQuality"
            android:layout_width="64dp"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_control_button"
            android:padding="0dp"
            android:text="@string/quality_hd"
            android:textColor="@color/status_text"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnRearCam"
            android:layout_width="64dp"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_control_button"
            android:padding="0dp"
            android:text="@string/btn_rear_cam"
            android:textColor="@color/status_text"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="64dp"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_control_button"
            android:padding="0dp"
            android:text="@string/btn_disconnect"
            android:textColor="@color/status_text"
            android:textSize="11sp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnLight"
            android:layout_width="64dp"
            android:layout_height="36dp"
            android:layout_marginBottom="8dp"
            android:background="@drawable/bg_control_button"
            android:padding="0dp"
            android:text="@string/light_off"
            android:textColor="@color/status_text"
            android:textSize="11sp" />

        <Button
            android:id="@+id/btnRecord"
            android:layout_width="64dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_control_button"
            android:padding="0dp"
            android:text="@string/btn_record_start"
            android:textColor="@color/status_text"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvRecordTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#FF4444"
            android:textSize="10sp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Left bottom: Throttle joystick (forward/backward) -->
    <com.example.remotecontrolcar.view.JoystickView
        android:id="@+id/joystickLeft"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="start|bottom"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="24dp" />

    <!-- Right bottom: Steering joystick (left/right) -->
    <com.example.remotecontrolcar.view.JoystickView
        android:id="@+id/joystickRight"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp" />

    <!-- Trim control: above right joystick -->
    <LinearLayout
        android:id="@+id/trimControl"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="end|bottom"
        android:layout_marginEnd="44dp"
        android:layout_marginBottom="170dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTrimLeft"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_control_button"
            android:padding="0dp"
            android:text="◀"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvTrimValue"
            android:layout_width="48dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_status_panel"
            android:gravity="center"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnTrimRight"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_control_button"
            android:padding="0dp"
            android:text="▶"
            android:textColor="@android:color/white"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Bottom center: Map / Speaker / Mic / Exposure -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal"
        android:gravity="center">

        <ImageButton
            android:id="@+id/btnMap"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_control_button"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_map_pin"
            android:contentDescription="@string/cd_map" />

        <ImageButton
            android:id="@+id/btnAudio"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_control_button"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_speaker_off"
            android:contentDescription="@string/cd_audio_off" />

        <ImageButton
            android:id="@+id/btnMic"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="32dp"
            android:background="@drawable/bg_control_button"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_mic_off"
            android:contentDescription="@string/cd_mic_off" />

        <!-- Volume button + floating panel above it -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="32dp">

            <ImageButton
                android:id="@+id/btnVolume"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_control_button"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_volume"
                android:contentDescription="@string/cd_volume" />

        </FrameLayout>

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <ImageButton
                android:id="@+id/btnExposure"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_control_button"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_exposure_sun"
                android:contentDescription="曝光控制" />

            <TextView
                android:id="@+id/tvExposureValue"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:background="@drawable/bg_control_button"
                android:textColor="@android:color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />

        </FrameLayout>

    </LinearLayout>

    <!-- Volume panel: vertical slider, floats above volume button -->
    <FrameLayout
        android:id="@+id/volumePanel"
        android:layout_width="56dp"
        android:layout_height="180dp"
        android:layout_gravity="bottom|end"
        android:layout_marginBottom="88dp"
        android:layout_marginEnd="156dp"
        android:background="@drawable/bg_status_panel"
        android:visibility="gone">

        <SeekBar
            android:id="@+id/seekVolume"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:max="9"
            android:progress="9"
            android:rotation="270" />

        <TextView
            android:id="@+id/tvVolumeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:layout_marginTop="4dp"
            android:text="10"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold" />

    </FrameLayout>

</FrameLayout>
